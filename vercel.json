{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "stridewithme.vercel.app" }],
      "destination": "https://stridewithme.club/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.stridewithme.club" }],
      "destination": "https://stridewithme.club/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "crons": [
    { "path": "/api/cron/check-reminders", "schedule": "30 14 * * *" }
  ]
}
